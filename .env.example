# ============================================
# LLM 配置
# ============================================
LLM_PROVIDER=claude
LLM_TEMPERATURE=0.0

# Claude 配置（原生 Anthropic API）
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ============================================
# Embedding 配置
# ============================================
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_EMBEDDING_MODEL=embo-01

# ============================================
# 数据源 API
# ============================================
POLYGON_API_KEY=your_polygon_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# MCP 服务器配置
# ============================================
# Local/native development defaults. Compose overrides this inside containers.
# Compose override: http://market-data-mcp:8000/mcp
# Market Data MCP Server (yfinance)
MCP_MARKET_DATA_HOST=127.0.0.1
MCP_MARKET_DATA_PORT=8000
MCP_MARKET_DATA_URL=http://127.0.0.1:8000/mcp

# Local/native development defaults. Compose overrides this inside containers.
# Compose override: http://news-search-mcp:8001/mcp
# News Search MCP Server (DuckDuckGo + Tavily)
MCP_NEWS_SEARCH_HOST=127.0.0.1
MCP_NEWS_SEARCH_PORT=8001
MCP_NEWS_SEARCH_URL=http://127.0.0.1:8001/mcp

# ============================================
# MiniMax 配置（备用）
# ============================================
# MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M2.5
# MINIMAX_EMBEDDING_MODEL=embo-01
# MINIMAX_GROUP_ID=your_group_id_here

# ============================================
# OKX 交易所配置
# ============================================
# OKX Demo Trading API (模拟盘)
OKX_DEMO_API_KEY=your_okx_demo_api_key_here
OKX_DEMO_SECRET_KEY=your_okx_demo_secret_key_here
OKX_DEMO_PASSPHRASE=your_okx_demo_passphrase_here

# OKX Live Trading API (实盘 - 暂时留空)
OKX_LIVE_API_KEY=
OKX_LIVE_SECRET_KEY=
OKX_LIVE_PASSPHRASE=

# Default mode
OKX_DEFAULT_MODE=demo

# ============================================
# 网络与代理配置
# ============================================
# 是否启用代理 (true/false)
USE_PROXY=false

# 可选：手动指定代理地址（如果不设置，WSL2 会自动探测）
# PROXY_URL=http://127.0.0.1:7890

# 可选：代理端口 (默认: 7890)
# PROXY_PORT=7890

# SSL 证书路径 (WSL2 环境必需)
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

# ============================================
# Redis 配置
# ============================================
# Local/native development default. Compose overrides this inside containers.
# Compose override: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=100
REDIS_SOCKET_TIMEOUT=2
REDIS_SOCKET_CONNECT_TIMEOUT=2
REDIS_POOL_TIMEOUT=1
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_ENABLED=true

# ============================================
# 限流器配置
# ============================================
INSTANCE_COUNT=4

# ============================================
# ARQ 任务队列配置
# ============================================
ARQ_WORKER_COUNT=2
ARQ_JOB_TIMEOUT=600
ARQ_KEEP_RESULT=3600

# ============================================
# Daily digest email configuration
# ============================================
DAILY_DIGEST_ENABLED=false
DAILY_DIGEST_TIME=08:00
DAILY_DIGEST_TIMEZONE=Asia/Shanghai
DAILY_DIGEST_RECIPIENTS=alice@example.com,bob@example.com
DAILY_DIGEST_FROM=bot@example.com
DAILY_DIGEST_TICKERS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,BTC,ETH
DAILY_DIGEST_MACRO_QUERY=US stock market macro economy Fed earnings bitcoin ethereum

# SMTP settings for daily digest delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=bot@example.com
SMTP_PASSWORD=secret
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false

# ============================================
# Stock catch-up configuration
# ============================================
STOCK_CATCHUP_ENABLED=true
STOCK_CATCHUP_DAYS=5
STOCK_RATE_LIMIT_DELAY=1.5

# ============================================
# Frontend 配置
# ============================================
# Frontend API URL (for Next.js browser requests).
# In the compose stack this stays http://localhost:8080 for host-browser access.
NEXT_PUBLIC_API_URL=http://localhost:8080
